alias ll='ls -l'
alias hgrep='history 1 | grep'
alias vimrc='vim ~/.vimrc'
alias restartz='source ~/.zshrc'

alias ia="open $1 -a /Applications/iA\ Writer.app"

alias mydns='scutil --dns | grep nameserver | sort -u'

# handy django aliases
alias djrun='python manage.py runserver localhost:3000'
alias djtest='pytest --no-migrations --ds=test_local_settings --ignore=node_modules'
